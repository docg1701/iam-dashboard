# IAM Dashboard - Staging Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@db:5432/advocacia_db

# Redis Configuration (for agent caching)
REDIS_URL=redis://redis:6379/0

# Application Configuration
ENVIRONMENT=staging
SECRET_KEY=staging-secret-key-change-in-production
DEBUG=false

# Google Gemini API
GEMINI_API_KEY=staging-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=embedding-001

# JWT Configuration
JWT_SECRET_KEY=staging-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# 2FA Configuration
TOTP_ISSUER_NAME=IAM Dashboard Staging

# Agent Management API Configuration
AGENT_API_BASE_URL=http://localhost:8080/v1

# Performance Settings for Staging
AGENT_MAX_CONCURRENT_TASKS=2
AGENT_TIMEOUT_SECONDS=180

# Monitoring and Logging
LOG_LEVEL=INFO
METRICS_ENABLED=true